{
  "info": {
    "name": "POS WMS JWT QA",
    "description": "QA collection for JWT gateway auth scenarios (AUTH-001..AUTH-005). Import directly into Postman.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00 - Login (Get Valid Token)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "login"
          ]
        },
        "description": "Login via gateway and capture valid access token into collection variable valid_token."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Login response has access token', function () {",
              "  var body = pm.response.json();",
              "  pm.expect(body).to.have.property('data');",
              "  pm.expect(body.data).to.have.property('access_token');",
              "  pm.expect(body.data.access_token).to.be.a('string').and.not.empty;",
              "});",
              "",
              "(function persistToken() {",
              "  var body = pm.response.json();",
              "  if (body && body.data && body.data.access_token) {",
              "    pm.collectionVariables.set('valid_token', body.data.access_token);",
              "  }",
              "})();"
            ]
          }
        }
      ]
    },
    {
      "name": "AUTH-001 - No Authorization Header",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/orders/123",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "orders",
            "123"
          ]
        },
        "description": "Expected 401 when Authorization header is missing."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 401', function () {",
              "  pm.response.to.have.status(401);",
              "});",
              "",
              "pm.test('Response has success=false', function () {",
              "  var body = pm.response.json();",
              "  pm.expect(body.success).to.eql(false);",
              "});",
              "",
              "pm.test('Response contains error field', function () {",
              "  var body = pm.response.json();",
              "  pm.expect(body).to.have.property('error');",
              "  pm.expect(body.error).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ]
    },
