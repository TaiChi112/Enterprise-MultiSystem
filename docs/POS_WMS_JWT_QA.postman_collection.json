    {
      "name": "AUTH-005 - Valid Token (Control)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{valid_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/orders/123",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "orders",
            "123"
          ]
        },
        "description": "Control case: valid token should pass gateway auth and be forwarded upstream."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is forwarded from upstream (not 401)', function () {",
              "  pm.expect(pm.response.code).to.not.eql(401);",
              "});",
              "",
              "pm.test('Gateway accepted valid token', function () {",
              "  pm.expect([200, 404, 400, 422]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "valid_token",
      "value": ""
