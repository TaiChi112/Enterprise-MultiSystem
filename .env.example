# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=pos_wms
DB_SSLMODE=disable

# Server Configuration
PORT=3000

# Rate Limiting Configuration (for /api/sales)
RATE_LIMIT_MAX=50
RATE_LIMIT_WINDOW=1s

# IAM Configuration
IAM_PORT=4001
IAM_JWT_SECRET=dev-secret-change-me
IAM_JWT_ISSUER=iam-api
IAM_JWT_TTL=1h

# CRM Configuration
CRM_PORT=4002

# OMS Configuration
OMS_PORT=4003

# SCM Configuration
SCM_PORT=4004
EDI_API_URL=http://edi-api:4005/edi/transmit
DEFAULT_SUPPLIER_ID=1
DEFAULT_REPLENISH_QTY=50
DEFAULT_SUPPLIER_NAME=Default Supplier
DEFAULT_SUPPLIER_CONTACT=default.supplier@example.com

# EDI Configuration
EDI_PORT=4005

# API Gateway Configuration
GATEWAY_PORT=8080
POS_API_URL=http://pos-api:3000
IAM_API_URL=http://iam-api:4001
CRM_API_URL=http://crm-api:4002
OMS_API_URL=http://oms-api:4003
SCM_API_URL=http://scm-api:4004
JWT_SECRET=dev-secret-change-me
JWT_ISSUER=iam-api
PROTECTED_PATHS=/api/orders,/api/customers,/scm
